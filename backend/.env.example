# configurações / segredos
PORT=
FRONTEND_URL=
NODE_ENV=
# Admin SDK (um dos dois): JSON completo da conta de serviço numa linha — preferido em App Runner / ECS.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Ou ficheiro local `config/credential.json` (CI também pode gerar antes do docker build — ver aws-backend-ecr.yml).
# Login (Identity Toolkit): chave Web do MESMO projeto Firebase — Project settings → General → Web API Key.
# Não está dentro do JSON da conta de serviço; tem de estar em variável de ambiente.
FIREBASE_WEB_API_KEY=
